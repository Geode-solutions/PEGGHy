{
  "name": "pegghy",
  "private": true,
  "type": "module",
  "scripts": {
    "clean_cache": "npx nuxi cleanup",
    "dev": "npm run dev:browser",
    "dev:browser": "cross-env MODE=BROWSER npm run dev:nuxt",
    "dev:nuxt": "npx nuxi dev --no-fork",
    "build:back": "npx opengeodeweb-microservice-pyinstaller ../PEGGHy-Back",
    "build:viewer": "npx opengeodeweb-microservice-pyinstaller ../PEGGHy-Viewer",
    "build:microservices": "concurrently \"npm run build:back\" \"npm run build:viewer\"",
    "build": "nuxi build",
    "build:browser": "cross-env MODE=BROWSER npm run build",
    "preview:browser": "node .output/server/index.mjs",
    "test:browser": "node node_scripts/browser.js preview:browser",
    "generate": "nuxt generate",
    "unpacked": "npm run build && electron-builder --dir",
    "package": "npm run build && electron-builder build --publish=never",
    "test:e2e:browser": "npx playwright test --config ./tests/e2e/browser/playwright.config.js",
    "test:e2e:cloud": "npx playwright test --config ./tests/e2e/cloud/playwright.config.js"
  },
  "dependencies": {
    "@geode/opengeodeweb-back": "0.0.0",
    "@geode/opengeodeweb-front": "0.0.0",
    "@geode/opengeodeweb-viewer": "0.0.0",
    "kill-port": "2.0.1"
  },
  "devDependencies": {
    "@nuxt/test-utils": "3.20.1",
    "@playwright/test": "1.54.1",
    "concurrently": "9.2.1",
    "cross-env": "10.0.0",
    "playwright": "1.54.1"
  },
  "dependencies": {
    "@geode/opengeodeweb-back": "0.0.0",
    "@geode/opengeodeweb-front": "0.0.0",
    "@geode/opengeodeweb-microservice": "0.0.0",
    "@geode/opengeodeweb-viewer": "0.0.0",
    "kill-port": "2.0.1"
  }
}
